{
  "manifest_version": 3,
  "name": "Remove disabled",
  "version": "1.1",
  "description": "右クリックメニューからページ内のすべてのdisabled属性を削除します。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  }
}